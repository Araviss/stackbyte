---
import type { TeamMember } from "../../types";

interface Props {
  member: TeamMember;
}

const { member } = Astro.props;
const initials = member.name
  .split(" ")
  .map((n) => n.charAt(0))
  .join("");
---

<div class="flex flex-col gap-5">
  <!-- Avatar: color block, no border -->
  <div class="w-14 h-14 bg-brand-yellow flex items-center justify-center font-black text-lg shrink-0">
    {initials}
  </div>

  <div>
    <h3 class="font-black text-xl">{member.name}</h3>
    <p class="font-mono text-xs uppercase tracking-widest text-brand-blue mt-1">{member.role}</p>
  </div>

  <p class="text-brand-black/60 text-sm leading-relaxed">{member.bio}</p>

  {member.linkedIn && (
    <a
      href={member.linkedIn}
      class="font-bold text-sm flex items-center gap-2 text-brand-black/40 hover:text-brand-red transition-colors duration-200 mt-auto"
      aria-label={`${member.name} on LinkedIn`}
    >
      LinkedIn <span aria-hidden="true">→</span>
    </a>
  )}
</div>
