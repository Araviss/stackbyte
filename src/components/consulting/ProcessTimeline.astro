---
import type { ProcessStep } from "../../types";

interface Props {
  steps: ProcessStep[];
}

const { steps } = Astro.props;
---

<!-- No wrapping border — steps separated by spacing and a thin divider only -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8">
  {steps.map((step) => (
    <div class="flex flex-col gap-4">
      <span class="font-mono font-black text-5xl text-brand-black/20 leading-none">
        {step.number}
      </span>
      <h3 class="font-black text-xl text-brand-black">{step.title}</h3>
      <p class="text-brand-black/60 text-sm leading-relaxed">{step.description}</p>
    </div>
  ))}
</div>
