---
import type { Service } from "../../types";

interface Props {
  service: Service;
  index: number;
}

const { service, index } = Astro.props;
---

<!-- Thin top rule only — no heavy box border -->
<div
  id={service.id}
  class="flex flex-col md:flex-row gap-10 py-16 border-t border-brand-black/10 first:border-0"
>
  <div class="md:w-1/3 shrink-0">
    <div class="md:sticky md:top-28">
      <span class="font-mono text-xs text-brand-yellow font-bold">0{index + 1}</span>
      <h3 class="font-black text-3xl mt-2">{service.title}</h3>
    </div>
  </div>
  <div class="md:w-2/3 flex flex-col gap-4">
    <p class="font-bold text-xl text-brand-red leading-snug">{service.summary}</p>
    <p class="text-brand-black/60 leading-relaxed text-lg">{service.description}</p>
  </div>
</div>
