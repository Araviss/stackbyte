---
import { DIFFERENTIATORS } from "../../content/home";
---

<section class="section-rule px-6 py-24 md:py-32">
  <div class="max-w-5xl mx-auto">
    <div class="text-center">
      <h2 class="text-display-sm">How we keep it sane</h2>
      <p class="font-hand mt-2 text-3xl md:text-4xl text-brand-black/65">
        A little process. A lot of clarity. Zero fog machines.
      </p>
    </div>

    <div class="mt-16 grid gap-12 md:grid-cols-3">
      {DIFFERENTIATORS.map((item) => (
        <div class="text-center">
          <div class="mx-auto mb-5 h-2 w-2 rounded-full bg-brand-red" aria-hidden="true"></div>
          <h3 class="text-xl font-black">{item.title}</h3>
          <p class="mt-4 leading-relaxed text-brand-black/60">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
