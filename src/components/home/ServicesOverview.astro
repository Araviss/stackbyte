---
import { SERVICES } from "../../content/services";

const plainEnglishServices = [
  {
    id: "web-design-development",
    title: "Web Development",
    summary:
      "Clear pages, fast load times, and a site you are not embarrassed to send people to.",
  },
  {
    id: "software-development",
    title: "Custom Software",
    summary:
      "Dashboards, portals, forms, and internal apps that replace the spreadsheet shuffle.",
  },
  {
    id: "modernization",
    title: "Software Cleanup",
    summary:
      "We clean up brittle systems, confusing workflows, and apps everyone depends on but nobody wants to touch.",
  },
  {
    id: "cloud-infrastructure",
    title: "Cloud & Reliability",
    summary:
      "Deployments, hosting, backups, monitoring, and the boring reliability work that keeps things running.",
  },
];

const homepageServices = plainEnglishServices
  .map((service) => ({
    ...service,
    description: SERVICES.find((item) => item.id === service.id)?.description ?? "",
  }));
---

<section class="section-rule px-6 py-20 md:py-28">
  <div class="max-w-6xl mx-auto">
    <div class="grid gap-8 md:grid-cols-[0.7fr_1.3fr] md:items-start">
      <div>
        <p class="font-hand text-3xl text-brand-black/55">plain english version</p>
        <h2 class="mt-3 text-display-sm">What we do</h2>
        <p class="mt-5 max-w-sm text-lg leading-relaxed text-brand-black/60">
          You do not need to know the perfect technical category. If the work is
          slow, fragile, or too manual, that is enough to start.
        </p>
        <div class="mt-8 flex flex-col">
          <img
            src="/images/collaboration.jpg"
            alt="Two developers collaborating"
            width="600"
            height="400"
            class="relative z-10 h-44 w-4/5 object-cover shadow-md"
            loading="lazy"
          />
          <img
            src="/images/code-screen.jpg"
            alt="Code on a screen"
            width="600"
            height="400"
            class="relative z-20 -mt-6 ml-12 h-44 w-4/5 object-cover shadow-md self-end"
            loading="lazy"
          />
          <img
            src="/images/server-racks.jpg"
            alt="Server racks"
            width="600"
            height="400"
            class="relative z-30 -mt-6 ml-4 h-44 w-4/5 object-cover shadow-md"
            loading="lazy"
          />
        </div>
      </div>

      <div class="grid gap-8">
        {homepageServices.map((service) => (
          <article class="border-t border-brand-black/10 pt-8">
            <h3 class="text-2xl md:text-3xl font-black">
              {service.title}
            </h3>
            <p class="mt-3 max-w-2xl text-lg md:text-xl leading-relaxed text-brand-black/65">
              {service.summary}
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
