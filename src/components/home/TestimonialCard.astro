---
import type { Testimonial } from "../../types";

interface Props {
  testimonial: Testimonial;
}

const { testimonial } = Astro.props;
---

<section class="section-rule px-6 py-24 md:py-32">
  <div class="max-w-4xl mx-auto text-center">
    <p class="font-hand text-4xl text-brand-red" aria-hidden="true">"</p>
    <blockquote class="mt-2">
      <p class="text-2xl md:text-4xl font-black leading-tight">
        {testimonial.quote}
      </p>
      <footer class="mt-8 text-brand-black/55">
        <span class="font-bold text-brand-black">{testimonial.author}</span>
        <span> / {testimonial.role}, {testimonial.company}</span>
      </footer>
    </blockquote>
  </div>
</section>
